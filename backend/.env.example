# Copy this file to ".env" and fill in your own values.

# Database connection settings
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-postgres-password
PGDATABASE=loginapp

# Secret used to sign login tokens (use a long random string)
JWT_SECRET=change-this-secret-in-production

# Base URL of the React app, used to build the password-reset link in emails.
FRONTEND_URL=http://localhost:5173

# Gmail account used to SEND notification emails.
# GMAIL_APP_PASSWORD must be a 16-character Google "App Password",
# NOT your normal Gmail password. Leave both blank to use a test inbox.
GMAIL_USER=
GMAIL_APP_PASSWORD=
